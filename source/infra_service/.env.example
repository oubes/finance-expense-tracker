# ------------ HTTP Client ------------# Application
APP_NAME="finance-expense-tracker"
APP_ENV="development"
DEBUG=True
LOG_LEVEL="INFO"

# Server
HOST="0.0.0.0"
PORT=8003

# Database (PostgreSQL)
