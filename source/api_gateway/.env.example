# ------------ Application ------------
APP_NAME="api-gateway"
APP_ENV="development"
DEBUG=True
LOG_LEVEL="INFO"

# ------------ Server ------------
HOST="0.0.0.0"
PORT=8000

# ------------ External Services (Local Dev) ------------
CHAT_SERVICE_URL="http://127.0.0.1:8001"
INGESTION_SERVICE_URL="http://127.0.0.1:8002"

# ------------ HTTP Client ------------
HTTP_TIMEOUT_SECONDS=10